---
import { getCollection } from "astro:content";
import Layout from "~/layouts/Layout.astro";
import BlogCard from "~/components/BlogCard";
import PageMigration from "~/components/PageMigration";

const blogEntries = await getCollection("blog");
const posts = blogEntries
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((entry) => ({
    id: entry.id,
    title: entry.data.title,
    description: entry.data.description ?? "",
    pubDate: entry.data.pubDate.toISOString(),
  }));
---

<Layout>
    <main
      class="flex justify-between px-[5vw] py-[10vh] h-screen overflow-hidden"
    >
      <div class="w-full h-screen flex justify-between overflow-hidden relative">
        <h1 class="h-full text-3xl font-sans-en tracking-wider">
          Welcome to Kz Creation Notes.
        </h1>

        <div class="h-full flex flex-col gap-8 items-end overflow-y-auto">
          {posts.length === 0 ? (
            <div class="text-center py-12">
              <p class="text-gray-500 font-sans-jp">まだ記事がありません。</p>
            </div>
          ) : (
            <div class="flex flex-col gap-6 items-end">
              {posts.map((post) => (
                <BlogCard
                  id={post.id}
                  title={post.title}
                  description={post.description}
                  pubDate={post.pubDate}
                />
              ))}
            </div>
          )}
        </div>
      </div>
    </main>
</Layout>
