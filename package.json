	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "node node_modules/.bin/vite dev",
		"build": "node node_modules/.bin/vite build",
		"preview": "node node_modules/.bin/vite preview",
		"prepare": "svelte-kit sync || echo ''",
